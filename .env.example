# ── BinBot AI Auto Mode — Environment Configuration ─────────────

# Database
DATABASE_URL=postgresql+asyncpg://binbot:binbot@postgres:5432/binbot
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://redis:6379/0

# Security
JWT_SECRET=generate-a-strong-random-secret-here
ENCRYPTION_KEY=generate-32-byte-key-for-aes-256

# Authentication
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-in-production

# Binance API (Live)
BINANCE_API_KEY=your-live-api-key
BINANCE_API_SECRET=your-live-api-secret

# Binance API (Testnet)
BINANCE_TESTNET_API_KEY=your-testnet-api-key
BINANCE_TESTNET_API_SECRET=your-testnet-api-secret

# Trading Mode: paper | testnet | live
# IMPORTANT: Live mode must be explicitly activated.
# Default is paper (no real orders placed).
TRADING_MODE=paper

# Telegram Notifications (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Debug
DEBUG=false
